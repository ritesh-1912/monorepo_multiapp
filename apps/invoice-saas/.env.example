# Copy to .env and fill in your values. NEVER commit .env.

# Database (Neon or any PostgreSQL). Required for API and auth.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# NextAuth. Required in production.
NEXTAUTH_SECRET=your-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Google OAuth – "Continue with Google" on login. See docs/GOOGLE_OAUTH_SETUP.md
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx

# Razorpay (India; used if set, else Stripe). Get from https://dashboard.razorpay.com/
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...  (from Dashboard → Settings → Webhooks)

# Stripe (if not using Razorpay). Not available in India for business.
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Resend (for sending invoice emails)
# RESEND_API_KEY=re_...
